{
  "family": "catalogue-prod",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::028597908565:role/catalogue-ecs-execution",
  "taskRoleArn": "arn:aws:iam::028597908565:role/catalogue-ecs-task",
  "containerDefinitions": [
    {
      "name": "app",
      "image": "PLACEHOLDER",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -sf http://localhost:8000/health || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 120
      },
      "environment": [
        { "name": "LOG_LEVEL", "value": "INFO" },
        { "name": "UPLOAD_DIR", "value": "/app/uploads" },
        { "name": "STORAGE_BACKEND", "value": "s3" },
        { "name": "COGNITO_USER_POOL_ID", "value": "eu-north-1_ThfApt8C5" },
        { "name": "COGNITO_CLIENT_ID", "value": "2n4pj4j9l45oj25i0t7sn3dko8" },
        { "name": "COGNITO_REGION", "value": "eu-north-1" },
        { "name": "ENVIRONMENT", "value": "production" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:028597908565:secret:catalogue-prod/DATABASE_URL"
        },
        {
          "name": "API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:028597908565:secret:catalogue-prod/API_KEY"
        },
        {
          "name": "S3_BUCKET",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:028597908565:secret:catalogue-prod/S3_BUCKET"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/catalogue-app",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "prod"
        }
      }
    }
  ]
}
