# Copy this file to .env and fill in values before running the application.
# .env is in .gitignore and must never be committed.

# -- Database ----------------------------------------------------------------
# Full PostgreSQL connection string.
DATABASE_URL=postgresql://catalogue:changeme@localhost/catalogue_tool

# -- Authentication ----------------------------------------------------------
# Shared API key. All API requests must include the header:
#   X-API-Key: <value>
# Leave empty to disable authentication (local development only).
API_KEY=replace-with-a-long-random-string

# -- Logging -----------------------------------------------------------------
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# -- Storage -----------------------------------------------------------------
# Directory for uploaded Excel files (relative to project root or absolute).
UPLOAD_DIR=uploads

# -- Docker Compose only -----------------------------------------------------
# Postgres password used inside docker-compose.yml.
POSTGRES_PASSWORD=changeme
