# Virtual environment
venv/

# Python
__pycache__/
*.pyc

# Runtime data – keep the directory but not the uploaded files
uploads/*
!uploads/.gitkeep

# OS
.DS_Store

# Test artifacts
.pytest_cache/
test*.txt
~$*

# InDesign documents and lock files (binaries; not committed)
*.indd
*.idlk
~*.idlk

# Environment
.env

# Sample files: only fixtures required by the automated tests are tracked, in
# the subfolder below. Everything else in test_sample_files/ is disposable /
# local-only working data and is not committed.
test_sample_files/*
!test_sample_files/tracked_samples_for_automated_tests/
